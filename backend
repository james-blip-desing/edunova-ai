const express = require("express")
const bodyParser = require("body-parser")
const cors = require("cors")

const app = express()

app.use(cors())
app.use(bodyParser.json())
app.use(express.static("public"))

const ADMIN_EMAIL = "toonlyrics22@gmail.com"

let users=[]
let questions=[]
let leaderboard=[]

const subjects=[
"Mathematics",
"English",
"Kiswahili",
"Biology",
"Chemistry",
"Physics",
"Geography",
"History",
"CRE",
"Agriculture",
"Business Studies",
"Computer Studies",
"Home Science"
]

function eduNovaAgent(subject){

const question=`KCSE ${subject} Question:
Explain one important concept in ${subject}.`

const explanation=`
Step 1: Identify the main concept.

Step 2: Break it into simple parts.

Step 3: Provide a clear explanation.

Step 4: Give an example.

Step 5: Summarize for KCSE revision.
`

return {question,explanation}

}

app.post("/login",(req,res)=>{

const {name,email}=req.body

let user=users.find(u=>u.email===email)

if(!user){

user={name,email,score:0}
users.push(user)

}

res.json(user)

})

app.get("/subjects",(req,res)=>{

res.json(subjects)

})

app.post("/generate",(req,res)=>{

const subject=req.body.subject

const result=eduNovaAgent(subject)

res.json(result)

})

app.post("/add-question",(req,res)=>{

if(req.body.email!==ADMIN_EMAIL){

return res.json({message:"Unauthorized"})
}

questions.push(req.body)

res.json({message:"Question added"})

})

app.get("/questions",(req,res)=>{

res.json(questions)

})

app.get("/mock",(req,res)=>{

res.json(questions.slice(0,10))

})

app.post("/submit",(req,res)=>{

const {email,score}=req.body

let user=users.find(u=>u.email===email)

if(user){

user.score+=score
}

leaderboard=users.sort((a,b)=>b.score-a.score)

res.json({message:"Score saved"})

})

app.get("/leaderboard",(req,res)=>{

res.json(leaderboard)

})

app.listen(3000,()=>{

console.log("EduNova AI running on port 3000")

})
